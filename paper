<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<title>文章比對工具（純網頁版）</title>
<style>
body { font-family: Arial; margin: 30px; }
textarea { width: 100%; height: 150px; margin-bottom: 20px; }
button { padding: 10px 20px; }
table { width: 100%; border-collapse: collapse; margin-top: 20px; }
th, td { border: 1px solid #ccc; padding: 8px; text-align: left; }
tr.high-similarity { background-color: #ffcccc; }
</style>
</head>
<body>

<h2>文章比對工具（純網頁版）</h2>

<label>文章 1：</label><br>
<textarea id="text1"></textarea><br>

<label>文章 2：</label><br>
<textarea id="text2"></textarea><br>

<button onclick="compare()">比對文章</button>

<h3 id="overall"></h3>
<table id="resultTable" style="display:none;">
<tr>
    <th>文章 1 段落</th>
    <th>匹配文章 2 段落</th>
    <th>相似度 (%)</th>
</tr>
</table>

<script>
// 計算兩段文字相似度 (簡單 SequenceMatcher 類比)
function similarity(s1, s2) {
    if (!s1 || !s2) return 0;
    let longer = s1.length > s2.length ? s1 : s2;
    let shorter = s1.length > s2.length ? s2 : s1;
    if (longer.length == 0) return 1.0;
    let same = 0;
    let minLen = shorter.length;
    for (let i=0;i<minLen;i++) {
        if (shorter[i]==longer[i]) same++;
    }
    return same / longer.length;
}

function compare() {
    const text1 = document.getElementById("text1").value.trim();
    const text2 = document.getElementById("text2").value.trim();
    const para1 = text1.split("\n").filter(p=>p.trim());
    const para2 = text2.split("\n").filter(p=>p.trim());

    let results = [];
    let totalSimilarity = 0;

    para1.forEach(p1 => {
        let maxSim = 0;
        let matched = "";
        para2.forEach(p2 => {
            let sim = similarity(p1,p2);
            if (sim > maxSim) {
                maxSim = sim;
                matched = p2;
            }
        });
        totalSimilarity += maxSim;
        results.push({paragraph: p1, matched: matched, similarity: Math.round(maxSim*100)});
    });

    let overallSim = (results.length>0 ? Math.round(totalSimilarity/results.length*100) : 0);
    document.getElementById("overall").innerHTML = `整篇相似度：<b>${overallSim}%</b>`;

    // 顯示表格
    const table = document.getElementById("resultTable");
    table.style.display = "table";
    // 清空原有
    table.innerHTML = `<tr>
        <th>文章 1 段落</th>
        <th>匹配文章 2 段落</th>
        <th>相似度 (%)</th>
    </tr>`;
    results.forEach(r=>{
        const row = table.insertRow();
        if (r.similarity>70) row.classList.add("high-similarity");
        row.insertCell(0).innerText = r.paragraph;
        row.insertCell(1).innerText = r.matched;
        row.insertCell(2).innerText = r.similarity;
    });
}
</script>

<p style="color:red;">紅色標記：相似度 > 70% 的段落，可能抄襲</p>

</body>
</html>
